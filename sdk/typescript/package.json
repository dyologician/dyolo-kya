{
  "name": "a1",
  "version": "2.8.0",
  "description": "TypeScript/Node.js client for A1: cryptographic identity and authorization for AI agents",
  "author": "dyolo <dyologician@users.noreply.github.com>",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/dyologician/a1",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyologician/a1.git"
  },
  "keywords": [
    "ai-agents",
    "delegation",
    "authorization",
    "cryptography",
    "langchain",
    "langgraph",
    "openai",
    "autogen",
    "crewai",
    "semantic-kernel",
    "zero-knowledge",
    "ed25519"
  ],
  "bugs": {
    "url": "https://github.com/dyologician/a1/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./integrations": {
      "import": {
        "types": "./dist/esm/integrations.d.ts",
        "default": "./dist/esm/integrations.js"
      },
      "require": {
        "types": "./dist/cjs/integrations.d.ts",
        "default": "./dist/cjs/integrations.js"
      }
    },
    "./passport": {
      "import": {
        "types": "./dist/esm/passport.d.ts",
        "default": "./dist/esm/passport.js"
      },
      "require": {
        "types": "./dist/cjs/passport.d.ts",
        "default": "./dist/cjs/passport.js"
      }
    },
    "./middleware": {
      "import": {
        "types": "./dist/esm/middleware.d.ts",
        "default": "./dist/esm/middleware.js"
      },
      "require": {
        "types": "./dist/cjs/middleware.d.ts",
        "default": "./dist/cjs/middleware.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2"
  },
  "optionalDependencies": {
    "@noble/ed25519": "^2.1.0"
  },
  "peerDependencies": {
    "@noble/ed25519": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "@noble/ed25519": {
      "optional": true
    }
  }
}
